<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<!-- 

to run a specific testng, goto the pom update the path in the maven compile dependencey and then in the terminal
give the command: mvn clean test

path needs to updated according to which testng is being run 
// parallel key word will run the three browser tests in parallel at the same time 
//this parallel can be kept in tests but then the syntax will be parallel ="classes", if parallel is kept in parent then the syntax has to have child
//thread-count =5 , this is optional but it creates 5 threads/processes if it is not added then only one thread/process is created, maximum 2-5 otherwise system might hang due to memory allocation
//multiple parameters can be passed like URL and then the test method will receive another parameter 
-->


<suite name ="dpsuite" data-provider-thread-count="2" parallel="tests"> 


<test name ="dptest">
<parameter name ="browser" value ="Chrome"/> 
<classes>
<class name="com.example.DataProvider.LogintestusingDataProvider"/>
</classes>
</test>

</suite>

